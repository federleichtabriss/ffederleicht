---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Danke für Ihre Anfrage | Federleicht Abriss";
const pageDescription = "Vielen Dank für Ihre Anfrage. Wir melden uns innerhalb von 24 Stunden bei Ihnen. Federleicht Abriss - Ihr Partner für Abriss & Entrümpelung in Sehnde.";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Success Section -->
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-metallic-platin/20" aria-labelledby="success-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Success Icon -->
      <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <h1 id="success-heading" class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6">
        Vielen Dank!
      </h1>
      
      <p class="text-xl text-gray-600 mb-4">
        Ihre Anfrage wurde erfolgreich übermittelt.
      </p>
      
      <p class="text-gray-600 mb-8 max-w-lg mx-auto">
        Wir haben Ihre Nachricht erhalten und werden uns innerhalb von <strong class="text-gray-900">24 Stunden</strong> bei Ihnen melden. 
        Bei dringenden Anliegen erreichen Sie uns auch telefonisch.
      </p>
      
      <!-- Next Steps -->
      <div class="bg-white rounded-2xl p-8 shadow-lg mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Was passiert als Nächstes?</h2>
        <div class="space-y-4 text-left">
          <div class="flex items-start space-x-4">
            <div class="w-8 h-8 bg-shiny-gold/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-shiny-gold font-bold text-sm">1</span>
            </div>
            <div>
              <p class="font-medium text-gray-900">Prüfung Ihrer Anfrage</p>
              <p class="text-gray-600 text-sm">Wir prüfen Ihre Anfrage und bereiten erste Informationen vor.</p>
            </div>
          </div>
          <div class="flex items-start space-x-4">
            <div class="w-8 h-8 bg-shiny-gold/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-shiny-gold font-bold text-sm">2</span>
            </div>
            <div>
              <p class="font-medium text-gray-900">Kontaktaufnahme</p>
              <p class="text-gray-600 text-sm">Wir rufen Sie an oder schreiben Ihnen per E-Mail.</p>
            </div>
          </div>
          <div class="flex items-start space-x-4">
            <div class="w-8 h-8 bg-shiny-gold/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-shiny-gold font-bold text-sm">3</span>
            </div>
            <div>
              <p class="font-medium text-gray-900">Kostenlose Besichtigung</p>
              <p class="text-gray-600 text-sm">Wir vereinbaren einen Termin vor Ort für ein unverbindliches Angebot.</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-8 py-4 bg-gray-900 text-white font-semibold rounded-lg shadow-lg hover:bg-gray-800 transition-all">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Zurück zur Startseite
        </a>
        <a href="tel:+491621689715" class="inline-flex items-center justify-center px-8 py-4 bg-shiny-gold text-white font-semibold rounded-lg shadow-lg hover:bg-yellow-600 transition-all">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          0155 67235344
        </a>
      </div>
      
      <!-- Contact Info -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <p class="text-gray-500 mb-2">Federleicht Abriss Entkernung und Entrümpelung</p>
        <p class="text-gray-500 text-sm">Johann-Wichernstrasse 9a, 31319 Sehnde</p>
        <p class="text-gray-500 text-sm mt-1">
          <a href="mailto:Ismaildag@ymail.com" class="hover:text-shiny-gold transition-colors">Ismaildag@ymail.com</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
