---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Federleicht Abriss | Professioneller Abriss, Entkernung & Entrümpelung in Sehnde";
const pageDescription = "Wir machen schwere Arbeit federleicht. Professioneller Abriss, Entkernung und Entrümpelung in Sehnde und Umgebung. Zertifiziert nach TRGS 519 & 521. Kostenlose Besichtigung!";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden" aria-label="Hero Bereich">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero.png" 
        alt="" 
        class="w-full h-full object-cover"
        decoding="async"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 via-gray-900/70 to-gray-900/40"></div>
    </div>
    
    <!-- Decorative Elements -->
    <div class="absolute top-20 right-10 w-64 h-64 bg-shiny-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-48 h-48 bg-shiny-gold/5 rounded-full blur-2xl"></div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <!-- Trust Badge -->
        <div class="inline-flex items-center space-x-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8 animate-fade-in">
          <svg class="w-5 h-5 text-shiny-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-white font-medium text-sm">Zertifiziert nach TRGS 519 & 521</span>
        </div>
        
        <!-- Main Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 animate-slide-up">
          Wir machen schwere Arbeit <span class="text-shiny-gold">federleicht.</span>
        </h1>
        
        <!-- Subheadline -->
        <p class="text-xl text-gray-300 mb-8 max-w-2xl animate-slide-up" style="animation-delay: 0.1s;">
          Professioneller Abriss, Entkernung und Entrümpelung in Sehnde und Umgebung. 
          Mit Sachverstand, Präzision und dem nötigen Feingefühl für Ihr Projekt.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-slide-up" style="animation-delay: 0.2s;">
          <a 
            href="/kontakt/#angebot" 
            class="inline-flex items-center justify-center px-8 py-4 bg-shiny-gold text-white font-semibold text-lg rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all transform hover:-translate-y-1"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Kostenlose Besichtigung
          </a>
          <a 
            href="tel:+491621689715" 
            class="inline-flex items-center justify-center px-8 py-4 bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white font-semibold text-lg rounded-lg hover:bg-white/20 transition-all"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            0155 67235344
          </a>
        </div>
        
        <!-- Trust Badges -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 animate-slide-up" style="animation-delay: 0.3s;">
          <div class="flex items-center space-x-2 text-white/80">
            <div class="w-10 h-10 rounded-full bg-shiny-gold/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-sm font-medium">Fester Preis</span>
          </div>
          <div class="flex items-center space-x-2 text-white/80">
            <div class="w-10 h-10 rounded-full bg-shiny-gold/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-sm font-medium">Termintreue</span>
          </div>
          <div class="flex items-center space-x-2 text-white/80">
            <div class="w-10 h-10 rounded-full bg-shiny-gold/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <span class="text-sm font-medium">Versichert</span>
          </div>
          <div class="flex items-center space-x-2 text-white/80">
            <div class="w-10 h-10 rounded-full bg-shiny-gold/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="text-sm font-medium">Saubere Arbeit</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Leistungen Overview -->
  <section class="py-24 bg-white" aria-labelledby="leistungen-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Unsere Leistungen</span>
        <h2 id="leistungen-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mt-2 mb-4">
          Alles aus einer Hand
        </h2>
        <p class="text-gray-600 text-lg">
          Von der ersten Besichtigung bis zur finalen Übergabe – wir begleiten Ihr Projekt 
          professionell und zuverlässig.
        </p>
      </div>
      
      <!-- Service Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Abriss -->
        <article class="group bg-metallic-platin/30 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
          <img 
            src="/images/leistung1.png" 
            alt="Professioneller Abriss von Gebäuden aller Art"
            class="w-full h-48 object-cover rounded-xl mb-6"
            loading="lazy"
            decoding="async"
          />
          <div class="w-16 h-16 bg-shiny-gold rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Abriss</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Fachgerechter Rückbau von Gebäuden aller Art – vom Einfamilienhaus bis zur Gewerbeimmobilie. 
            Inklusive Entsorgung und dokumentierter Abnahme.
          </p>
          <a href="/leistungen/#abriss" class="inline-flex items-center text-shiny-gold font-semibold hover:text-yellow-600 transition-colors">
            Mehr erfahren
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </article>
        
        <!-- Entkernung -->
        <article class="group bg-metallic-platin/30 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
          <img 
            src="/images/leistung2.png" 
            alt="Fachgerechte Entkernung von Wohn- und Geschäftsräumen"
            class="w-full h-48 object-cover rounded-xl mb-6"
            loading="lazy"
            decoding="async"
          />
          <div class="w-16 h-16 bg-shiny-gold rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Entkernung</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Professionelle Entkernung von Wohn- und Geschäftsräumen für Sanierung oder Neuausstattung. 
            Besonders sensibel bei Altbausanierungen.
          </p>
          <a href="/leistungen/#entkernung" class="inline-flex items-center text-shiny-gold font-semibold hover:text-yellow-600 transition-colors">
            Mehr erfahren
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </article>
        
        <!-- Entrümpelung -->
        <article class="group bg-metallic-platin/30 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
          <img 
            src="/images/leistung3.png" 
            alt="Schnelle und diskrete Entrümpelung von Wohnungen und Kellern"
            class="w-full h-48 object-cover rounded-xl mb-6"
            loading="lazy"
            decoding="async"
          />
          <div class="w-16 h-16 bg-shiny-gold rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Entrümpelung</h3>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Schnelle und diskrete Entrümpelung von Wohnungen, Kellern, Garagen und Gewerberäumen. 
            Inklusive fachgerechter Entsorgung und Recycling.
          </p>
          <a href="/leistungen/#entruempelung" class="inline-flex items-center text-shiny-gold font-semibold hover:text-yellow-600 transition-colors">
            Mehr erfahren
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </article>
      </div>
      
      <!-- CTA -->
      <div class="text-center mt-12">
        <a href="/leistungen/" class="inline-flex items-center px-8 py-4 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition-colors">
          Alle Leistungen im Überblick
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Warum Wir / Zertifikate -->
  <section class="py-24 bg-gray-900 relative overflow-hidden" aria-labelledby="zertifikate-heading">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Content -->
        <div>
          <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Warum wir?</span>
          <h2 id="zertifikate-heading" class="text-3xl sm:text-4xl font-bold text-white mt-2 mb-6">
            Ihre Sicherheit hat Priorität
          </h2>
          <p class="text-gray-300 text-lg mb-8 leading-relaxed">
            Bei Asbest und alter Mineralwolle gibt es keine Kompromisse. Als zertifizierter Fachbetrieb 
            schützen wir Sie vor gesundheitlichen Risiken und rechtlichen Konsequenzen.
          </p>
          
          <!-- Certificate Cards -->
          <div class="space-y-4 mb-8">
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6 flex items-start space-x-4">
              <div class="w-12 h-12 bg-shiny-gold rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white mb-1">TRGS 519 – Großer Asbestschein</h3>
                <p class="text-gray-400 text-sm">
                  Berechtigung zur Sanierung von asbesthaltigen Materialien bis Stufe D. 
                  Vollständiger Schutz für Sie und Ihre Immobilie.
                </p>
              </div>
            </div>
            
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6 flex items-start space-x-4">
              <div class="w-12 h-12 bg-shiny-gold rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white mb-1">TRGS 521 – Mineralwolle</h3>
                <p class="text-gray-400 text-sm">
                  Fachkundige Entsorgung von alter Mineralwolle nach aktuellen Vorschriften. 
                  Gesundheitsschutz für alle Beteiligten.
                </p>
              </div>
            </div>
          </div>
          
          <a href="/ueber-uns/" class="inline-flex items-center text-shiny-gold font-semibold hover:text-yellow-400 transition-colors">
            Mehr über unsere Qualifikationen
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-4 bg-shiny-gold/20 rounded-3xl blur-2xl"></div>
          <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-4">
            <img 
              src="/images/uberuns.png" 
              alt="Das Federleicht Abriss Team bei der Arbeit" 
              class="w-full h-auto rounded-xl"
              loading="lazy"
              decoding="async"
            />
            <!-- Badge Overlay -->
            <div class="absolute bottom-8 left-8 right-8 bg-white rounded-xl p-4 shadow-xl">
              <div class="flex items-center space-x-3">
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>

                  <p class="text-sm text-gray-600">Regelmäßige Überwachung & Fortbildung</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Prozess Section -->
  <section class="py-24 bg-metallic-platin/20" aria-labelledby="prozess-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">So funktioniert's</span>
        <h2 id="prozess-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mt-2 mb-4">
          Drei einfache Schritte zum Erfolg
        </h2>
        <p class="text-gray-600 text-lg">
          Unser bewährter Prozess garantiert eine reibungslose Abwicklung Ihres Projekts – 
          von der ersten Anfrage bis zur finalen Übergabe.
        </p>
      </div>
      
      <!-- Process Steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Connection Line (Desktop) -->
        <div class="hidden md:block absolute top-24 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-shiny-gold/30 via-shiny-gold to-shiny-gold/30"></div>
        
        <!-- Step 1 -->
        <div class="relative">
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow relative z-10">
            <div class="w-16 h-16 bg-shiny-gold rounded-full flex items-center justify-center text-white text-2xl font-bold mb-6 mx-auto shadow-lg">
              1
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-metallic-platin rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">Kostenlose Besichtigung</h3>
              <p class="text-gray-600">
                Wir besichtigen Ihr Objekt vor Ort, analysieren die Anforderungen und besprechen 
                Ihre Wünsche und Vorstellungen im Detail.
              </p>
            </div>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="relative">
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow relative z-10">
            <div class="w-16 h-16 bg-shiny-gold rounded-full flex items-center justify-center text-white text-2xl font-bold mb-6 mx-auto shadow-lg">
              2
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-metallic-platin rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">Festpreis-Angebot</h3>
              <p class="text-gray-600">
                Sie erhalten innerhalb von 24 Stunden ein transparentes Angebot mit Festpreis – 
                ohne versteckte Kosten oder Überraschungen.
              </p>
            </div>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="relative">
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow relative z-10">
            <div class="w-16 h-16 bg-shiny-gold rounded-full flex items-center justify-center text-white text-2xl font-bold mb-6 mx-auto shadow-lg">
              3
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-metallic-platin rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">Professionelle Umsetzung</h3>
              <p class="text-gray-600">
                Wir führen die Arbeit termingerecht und fachgerecht durch. Nach Abschluss erfolgt 
                die dokumentierte Übergabe Ihres sanierten Objekts.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lead Gen / Kontaktformular Section -->
  <section id="angebot" class="py-24 bg-white" aria-labelledby="kontakt-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Content -->
        <div>
          <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Kostenloses Angebot</span>
          <h2 id="kontakt-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mt-2 mb-6">
            Lassen Sie uns über Ihr Projekt sprechen
          </h2>
          <p class="text-gray-600 text-lg mb-8">
            Füllen Sie das Formular aus und wir melden uns innerhalb von 24 Stunden bei Ihnen. 
            Die Erstbesichtigung ist für Sie völlig kostenlos und unverbindlich.
          </p>
          
          <!-- Contact Info Cards -->
          <div class="space-y-4">
            <div class="flex items-center space-x-4 p-4 bg-metallic-platin/30 rounded-xl">
              <div class="w-12 h-12 bg-shiny-gold rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-500">Telefon</p>
                <a href="tel:+491621689715" class="text-lg font-semibold text-gray-900 hover:text-shiny-gold transition-colors">0155 67235344</a>
              </div>
            </div>
            
            <div class="flex items-center space-x-4 p-4 bg-metallic-platin/30 rounded-xl">
              <div class="w-12 h-12 bg-shiny-gold rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-500">E-Mail</p>
                <a href="mailto:Ismaildag@ymail.com" class="text-lg font-semibold text-gray-900 hover:text-shiny-gold transition-colors">Ismaildag@ymail.com</a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Form -->
        <div class="bg-metallic-platin/20 rounded-2xl p-8">
          <form 
            action="https://api.web3forms.com/submit" 
            method="POST" 
            class="space-y-6"
            aria-label="Kontaktformular"
          >
            <!-- Web3Forms Hidden Fields -->
            <input type="hidden" name="access_key" value="89095fef-e457-4ba7-935f-41f81e295ba5" />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="subject" value="Neue Anfrage über Federleicht-Abriss.de" />
            <input type="hidden" name="from_name" value="Federleicht Abriss Website" />
            <input type="hidden" name="redirect" value="https://federleicht-abriss.de/danke/" />
            
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                Name <span class="text-red-500" aria-label="Pflichtfeld">*</span>
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                placeholder="Ihr vollständiger Name"
                autocomplete="name"
              />
            </div>
            
            <!-- Phone & Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                  Telefon <span class="text-red-500" aria-label="Pflichtfeld">*</span>
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                  placeholder="Ihre Telefonnummer"
                  autocomplete="tel"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  E-Mail
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                  placeholder="Ihre E-Mail-Adresse"
                  autocomplete="email"
                />
              </div>
            </div>
            
            <!-- Service Type -->
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-2">
                Gewünschte Leistung
              </label>
              <select 
                id="service" 
                name="service"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all bg-white"
              >
                <option value="">Bitte wählen...</option>
                <option value="abriss">Abriss</option>
                <option value="entkernung">Entkernung</option>
                <option value="entruempelung">Entrümpelung</option>
                <option value="kombination">Kombination mehrerer Leistungen</option>
                <option value="unsicher">Noch unsicher / Beratung gewünscht</option>
              </select>
            </div>
            
            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Ihre Nachricht
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all resize-none"
                placeholder="Beschreiben Sie kurz Ihr Projekt..."
              ></textarea>
            </div>
            
            <!-- Privacy Checkbox -->
            <div class="flex items-start space-x-3">
              <input 
                type="checkbox" 
                id="privacy" 
                name="privacy" 
                required
                class="w-5 h-5 mt-0.5 text-shiny-gold border-gray-300 rounded focus:ring-shiny-gold"
              />
              <label for="privacy" class="text-sm text-gray-600">
                Ich habe die <a href="/datenschutz/" class="text-shiny-gold hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-red-500" aria-label="Pflichtfeld">*</span>
              </label>
            </div>
            
            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full px-8 py-4 bg-shiny-gold text-white font-semibold text-lg rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all transform hover:-translate-y-0.5"
            >
              Anfrage senden
            </button>
            
            <p class="text-xs text-gray-500 text-center">
              * Pflichtfelder | Ihre Daten werden gemäß DSGVO verarbeitet.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / Social Proof Section -->
  <section class="py-16 bg-metallic-platin/30" aria-label="Vertrauensindikatoren">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-shiny-gold mb-2">✓</div>
          <p class="text-gray-600">Viele zufriedene Kunden</p>
        </div>
        <div>
          <div class="text-4xl font-bold text-shiny-gold mb-2">100%</div>
          <p class="text-gray-600">Zufriedene Kunden</p>
        </div>
        <div>
          <div class="text-4xl font-bold text-shiny-gold mb-2">24h</div>
          <p class="text-gray-600">Antwortgarantie</p>
        </div>
        <div>
          <div class="text-4xl font-bold text-shiny-gold mb-2">10+</div>
          <p class="text-gray-600">Jahre Erfahrung</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
