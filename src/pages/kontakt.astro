---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Kontakt | Federleicht Abriss in Sehnde - Kostenloses Angebot";
const pageDescription = "Kontaktieren Sie Federleicht Abriss für ein kostenloses Angebot. Tel: 0155 67235344 | Ismail Dag | Johann-Wichernstrasse 9a, 31319 Sehnde. Jetzt Termin vereinbaren!";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Page Header -->
  <section class="relative py-20 bg-gray-900" aria-labelledby="page-title">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Wir sind für Sie da</span>
        <h1 id="page-title" class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-4">
          Kontakt
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Haben Sie Fragen oder möchten ein unverbindliches Angebot? 
          Wir melden uns innerhalb von 24 Stunden bei Ihnen.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section class="py-16 bg-metallic-platin/20 -mt-8 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Phone Card -->
        <a href="tel:+4915567235344" class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 text-center">
          <div class="w-16 h-16 bg-shiny-gold/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-shiny-gold group-hover:scale-110 transition-all">
            <svg class="w-8 h-8 text-shiny-gold group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 mb-2">Telefon</h2>
          <p class="text-shiny-gold font-bold text-xl">0155 67235344</p>
          <p class="text-gray-500 text-sm mt-2">Mo-Sa erreichbar</p>
        </a>
        
        <!-- Email Card -->
        <a href="mailto:Ismaildag@ymail.com" class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 text-center">
          <div class="w-16 h-16 bg-shiny-gold/10 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-shiny-gold group-hover:scale-110 transition-all">
            <svg class="w-8 h-8 text-shiny-gold group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 mb-2">E-Mail</h2>
          <p class="text-shiny-gold font-bold text-lg break-all">Ismaildag@ymail.com</p>
          <p class="text-gray-500 text-sm mt-2">Antwort innerhalb 24h</p>
        </a>
        
        <!-- Address Card -->
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="w-16 h-16 bg-shiny-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 mb-2">Adresse</h2>
          <p class="text-gray-700 font-medium">Johann-Wichernstrasse 9a</p>
          <p class="text-gray-700">31319 Sehnde</p>
          <p class="text-gray-500 text-sm mt-2">Deutschland</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Opening Hours -->
  <section class="py-16 bg-white" aria-labelledby="opening-hours-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Erreichbarkeit</span>
          <h2 id="opening-hours-heading" class="text-3xl font-bold text-gray-900 mt-2">
            Öffnungszeiten
          </h2>
        </div>
        
        <div class="bg-metallic-platin/20 rounded-2xl p-8">
          <div class="space-y-4">
            <div class="flex justify-between items-center py-3 border-b border-gray-200">
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="font-medium text-gray-900">Montag - Freitag</span>
              </div>
              <span class="font-semibold text-gray-900">08:00 - 18:00 Uhr</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-gray-200">
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="font-medium text-gray-900">Samstag</span>
              </div>
              <span class="font-semibold text-gray-900">09:00 - 14:00 Uhr</span>
            </div>
            <div class="flex justify-between items-center py-3">
              <div class="flex items-center space-x-3">
                <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="font-medium text-gray-900">Sonntag</span>
              </div>
              <span class="font-semibold text-red-500">Geschlossen</span>
            </div>
          </div>
          
          <div class="mt-6 p-4 bg-shiny-gold/10 rounded-xl">
            <p class="text-sm text-gray-700 text-center">
              <span class="font-semibold">Notfälle?</span> Rufen Sie uns an – wir sind auch außerhalb der Öffnungszeiten für Sie da.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="angebot" class="py-24 bg-metallic-platin/20" aria-labelledby="form-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Form Content -->
        <div>
          <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Kostenloses Angebot</span>
          <h2 id="form-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mt-2 mb-6">
            Schreiben Sie uns
          </h2>
          <p class="text-gray-600 text-lg mb-8">
            Füllen Sie das Formular aus und wir melden uns innerhalb von 24 Stunden bei Ihnen. 
            Die Erstbesichtigung ist für Sie völlig kostenlos und unverbindlich.
          </p>
          
          <!-- Trust Badges -->
          <div class="space-y-4">
            <div class="flex items-center space-x-3 text-gray-700">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Kostenlose Erstbesichtigung</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-700">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Festpreis ohne versteckte Kosten</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-700">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>DSGVO-konforme Datenverarbeitung</span>
            </div>
          </div>
        </div>
        
        <!-- Web3Forms Form -->
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <form 
            action="https://api.web3forms.com/submit" 
            method="POST" 
            class="space-y-6"
            aria-label="Kontaktformular"
            id="contact-form"
          >
            <!-- Web3Forms Hidden Fields -->
            <input type="hidden" name="access_key" value="89095fef-e457-4ba7-935f-41f81e295ba5" />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <input type="hidden" name="subject" value="Neue Anfrage über Federleicht-Abriss.de" />
            <input type="hidden" name="from_name" value="Federleicht Abriss Website" />
            <input type="hidden" name="redirect" value="https://federleicht-abriss.de/danke/" />
            
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                Name <span class="text-red-500" aria-label="Pflichtfeld">*</span>
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                placeholder="Ihr vollständiger Name"
                autocomplete="name"
              />
            </div>
            
            <!-- Phone & Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                  Telefon <span class="text-red-500" aria-label="Pflichtfeld">*</span>
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                  placeholder="Ihre Telefonnummer"
                  autocomplete="tel"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  E-Mail
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                  placeholder="Ihre E-Mail-Adresse"
                  autocomplete="email"
                />
              </div>
            </div>
            
            <!-- Service Type -->
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-2">
                Gewünschte Leistung
              </label>
              <select 
                id="service" 
                name="service"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all bg-white"
              >
                <option value="">Bitte wählen...</option>
                <option value="abriss">Abriss</option>
                <option value="entkernung">Entkernung</option>
                <option value="entruempelung">Entrümpelung</option>
                <option value="asbestsanierung">Asbestsanierung</option>
                <option value="mineralwolle">Mineralwolle-Entsorgung</option>
                <option value="kombination">Kombination mehrerer Leistungen</option>
                <option value="unsicher">Noch unsicher / Beratung gewünscht</option>
              </select>
            </div>
            
            <!-- Address -->
            <div>
              <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
                Adresse des Objekts
              </label>
              <input 
                type="text" 
                id="address" 
                name="address"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
                placeholder="Straße, PLZ, Ort"
                autocomplete="street-address"
              />
            </div>
            
            <!-- Preferred Date -->
            <div>
              <label for="preferred_date" class="block text-sm font-medium text-gray-700 mb-2">
                Gewünschter Besichtigungstermin
              </label>
              <input 
                type="date" 
                id="preferred_date" 
                name="preferred_date"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all"
              />
            </div>
            
            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Ihre Nachricht
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-shiny-gold focus:ring-2 focus:ring-shiny-gold/20 outline-none transition-all resize-none"
                placeholder="Beschreiben Sie kurz Ihr Projekt, die ungefähre Größe des Objekts und weitere wichtige Details..."
              ></textarea>
            </div>
            
            <!-- Privacy Checkbox -->
            <div class="flex items-start space-x-3">
              <input 
                type="checkbox" 
                id="privacy" 
                name="privacy" 
                required
                class="w-5 h-5 mt-0.5 text-shiny-gold border-gray-300 rounded focus:ring-shiny-gold"
              />
              <label for="privacy" class="text-sm text-gray-600">
                Ich habe die <a href="/datenschutz/" class="text-shiny-gold hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten gemäß DSGVO zu. <span class="text-red-500" aria-label="Pflichtfeld">*</span>
              </label>
            </div>
            
            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full px-8 py-4 bg-shiny-gold text-white font-semibold text-lg rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all transform hover:-translate-y-0.5 flex items-center justify-center"
              id="submit-btn"
            >
              <span>Anfrage senden</span>
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
            
            <!-- Form Status Messages -->
            <div id="form-success" class="hidden p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg" role="alert">
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Vielen Dank! Ihre Anfrage wurde erfolgreich gesendet.</span>
              </div>
            </div>
            
            <div id="form-error" class="hidden p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg" role="alert">
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <span>Es ist ein Fehler aufgetreten. Bitte versuchen Sie es später erneut.</span>
              </div>
            </div>
            
            <p class="text-xs text-gray-500 text-center">
              * Pflichtfelder | Ihre Daten werden verschlüsselt übertragen und gemäß DSGVO verarbeitet.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="py-16 bg-white" aria-labelledby="map-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 id="map-heading" class="text-2xl font-bold text-gray-900">
          So finden Sie uns
        </h2>
        <p class="text-gray-600 mt-2">
          Johann-Wichernstrasse 9a, 31319 Sehnde
        </p>
      </div>
      
      <!-- Google Maps Embed -->
      <div class="relative w-full aspect-video md:aspect-[16/9] lg:aspect-[21/9] rounded-2xl overflow-hidden shadow-lg bg-metallic-platin">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d38920.44236397562!2d9.946772!3d52.313605!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b00b5c9a6e9f65%3A0x8c3f9e8f5c8b5d5e!2sJohann-Wichernstra%C3%9Fe%209a%2C%2031319%20Sehnde%2C%20Deutschland!5e0!3m2!1sde!2sde!4v1700000000000!5m2!1sde!2sde"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Google Maps - Federleicht Abriss Standort"
          class="absolute inset-0 w-full h-full"
        ></iframe>
      </div>
      
      <!-- Map Fallback Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-6">
        <a 
          href="https://maps.google.com/?q=Johann-Wichernstrasse+9a+31319+Sehnde" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 bg-shiny-gold text-white font-medium rounded-lg hover:bg-yellow-600 transition-colors shadow-md"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          In Google Maps öffnen
        </a>
        <a 
          href="https://www.google.com/maps/dir/?api=1&destination=Johann-Wichernstrasse+9a+31319+Sehnde" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 bg-white text-gray-700 border border-gray-300 font-medium rounded-lg hover:bg-gray-50 transition-colors shadow-sm"
        >
          <svg class="w-5 h-5 mr-2 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.447-.894L15 7m0 13V7" />
          </svg>
          Route planen
        </a>
      </div>
      
      <p class="text-sm text-gray-500 text-center mt-4">
        Bitte vereinbaren Sie vorab einen Termin, da wir häufig auf Baustellen unterwegs sind.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-shiny-gold" aria-label="Call to Action">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Lieber direkt sprechen?
      </h2>
      <p class="text-white/90 text-lg mb-8">
        Rufen Sie uns an – wir beraten Sie gerne persönlich und unverbindlich.
      </p>
      <a href="tel:+4915567235344" class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-900 font-semibold text-lg rounded-lg shadow-lg hover:shadow-xl hover:bg-gray-100 transition-all">
        <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        0155 67235344
      </a>
    </div>
  </section>
</Layout>

<script>
  // Client-side form validation enhancement
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    
    if (form) {
      form.addEventListener('submit', function(e) {
        // Show loading state
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = `
