---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Leistungen | Abriss, Entkernung & Entrümpelung in Sehnde";
const pageDescription = "Professionelle Leistungen für Abriss, Entkernung und Entrümpelung in Sehnde und Umgebung. Zertifizierte Gefahrstoffentsorgung nach TRGS 519 & 521. Jetzt informieren!";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Page Header -->
  <section class="relative py-20 bg-gray-900" aria-labelledby="page-title">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Unser Service</span>
        <h1 id="page-title" class="text-4xl sm:text-5xl font-bold text-white mt-2 mb-4">
          Professionelle Leistungen
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Von der fachgerechten Entsorgung bis zur kompletten Entkernung – 
          wir bieten Ihnen alle Dienstleistungen aus einer Hand.
        </p>
      </div>
    </div>
  </section>

  <!-- Abriss Section -->
  <section id="abriss" class="py-24 bg-white" aria-labelledby="abriss-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Content -->
        <div>
          <div class="inline-flex items-center space-x-2 bg-shiny-gold/10 rounded-full px-4 py-2 mb-6">
            <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <span class="text-shiny-gold font-medium text-sm">Leistung 01</span>
          </div>
          
          <h2 id="abriss-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
            Fachgerechter Abriss
          </h2>
          
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            Wir übernehmen den Rückbau von Gebäuden jeder Größenordnung – vom kleinen Gartenhäuschen 
            bis zur großen Gewerbeimmobilie. Dabei achten wir stets auf maximale Sicherheit, 
            Umweltverträglichkeit und termingerechte Ausführung.
          </p>
          
          <ul class="space-y-4 mb-8">
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Rückbau von Einfamilienhäusern und Mehrfamilienhäusern</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Gewerblicher Abriss von Hallen und Fabrikgebäuden</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Teilabbruch und Rückbau einzelner Gebäudeteile</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Fachgerechte Trennung und Entsorgung aller Materialien</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Dokumentierte Übergabe und Abnahme</span>
            </li>
          </ul>
          
          <a href="/kontakt/#angebot" class="inline-flex items-center px-6 py-3 bg-shiny-gold text-white font-semibold rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all">
            Angebot für Abriss anfordern
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-4 bg-shiny-gold/10 rounded-3xl blur-2xl"></div>
          <div class="relative bg-metallic-platin/50 rounded-2xl p-4">
            <img 
              src="/images/leistung1.png" 
              alt="Fachgerechter Abriss eines Gebäudes durch das Team von Federleicht" 
              class="w-full h-auto rounded-xl"
              loading="lazy"
              decoding="async"
              width="800"
              height="600"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Entkernung Section -->
  <section id="entkernung" class="py-24 bg-metallic-platin/20" aria-labelledby="entkernung-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Image (Left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-4 bg-shiny-gold/10 rounded-3xl blur-2xl"></div>
          <div class="relative bg-metallic-platin/50 rounded-2xl p-4">
            <img 
              src="/images/leistung2.png" 
              alt="Professionelle Entkernung eines Wohnraums vor der Sanierung" 
              class="w-full h-auto rounded-xl"
              loading="lazy"
              decoding="async"
              width="800"
              height="600"
            />
          </div>
        </div>
        
        <!-- Content -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center space-x-2 bg-shiny-gold/10 rounded-full px-4 py-2 mb-6">
            <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
            <span class="text-shiny-gold font-medium text-sm">Leistung 02</span>
          </div>
          
          <h2 id="entkernung-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
            Professionelle Entkernung
          </h2>
          
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            Die Entkernung ist der erste Schritt für eine erfolgreiche Sanierung oder Modernisierung. 
            Wir entfernen alle nichttragenden Bauteile fachgerecht und hinterlassen Ihnen eine 
            saubere Baustelle für die Weiterverarbeitung.
          </p>
          
          <ul class="space-y-4 mb-8">
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Komplette Entkernung von Wohn- und Gewerberäumen</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Entfernung von Böden, Wandverkleidungen und Decken</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Ausbau von Küchen, Bädern und Einbauten</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Schonende Entkernung bei Altbausanierungen</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Trennung und Recycling von Baustoffen</span>
            </li>
          </ul>
          
          <a href="/kontakt/#angebot" class="inline-flex items-center px-6 py-3 bg-shiny-gold text-white font-semibold rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all">
            Angebot für Entkernung anfordern
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Entrümpelung Section -->
  <section id="entruempelung" class="py-24 bg-white" aria-labelledby="entruempelung-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Content -->
        <div>
          <div class="inline-flex items-center space-x-2 bg-shiny-gold/10 rounded-full px-4 py-2 mb-6">
            <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            <span class="text-shiny-gold font-medium text-sm">Leistung 03</span>
          </div>
          
          <h2 id="entruempelung-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
            Schnelle Entrümpelung
          </h2>
          
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            Ob Wohnungsauflösung, Kellerentrümpelung oder die Räumung eines Gewerbebetriebs – 
            wir entrümpeln schnell, diskret und zu fairen Preisen. Alle Wertgegenstände werden 
            selbstverständlich herausgefiltert und Ihnen übergeben.
          </p>
          
          <ul class="space-y-4 mb-8">
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Wohnungsauflösungen und Haushaltsauflösungen</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Keller-, Dachboden- und Garagenentrümpelung</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Gewerbliche Entrümpelung von Büros und Lagerhallen</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Herausfilterung von Wertgegenständen</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-6 h-6 text-shiny-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Fachgerechte Entsorgung und Recycling</span>
            </li>
          </ul>
          
          <a href="/kontakt/#angebot" class="inline-flex items-center px-6 py-3 bg-shiny-gold text-white font-semibold rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all">
            Angebot für Entrümpelung anfordern
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        
        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-4 bg-shiny-gold/10 rounded-3xl blur-2xl"></div>
          <div class="relative bg-metallic-platin/50 rounded-2xl p-4">
            <img 
              src="/images/leistung3.png" 
              alt="Diskrete und professionelle Entrümpelung eines Haushalts" 
              class="w-full h-auto rounded-xl"
              loading="lazy"
              decoding="async"
              width="800"
              height="600"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gefahrstoffe Section -->
  <section class="py-24 bg-gray-900 relative overflow-hidden" aria-labelledby="gefahrstoffe-heading">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-shiny-gold font-semibold tracking-wide uppercase text-sm">Sicherheit first</span>
        <h2 id="gefahrstoffe-heading" class="text-3xl sm:text-4xl font-bold text-white mt-2 mb-4">
          Fachgerechte Gefahrstoffentsorgung
        </h2>
        <p class="text-gray-400 text-lg">
          Bei der Sanierung älterer Gebäude stoßen wir häufig auf Asbest und alte Mineralwolle. 
          Dank unserer Zertifizierungen können wir diese Stoffe fachgerecht für Sie entsorgen.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Asbest Card -->
        <article class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 hover:border-shiny-gold/50 transition-colors">
          <div class="w-16 h-16 bg-red-500/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Asbestsanierung (TRGS 519)</h3>
          <p class="text-gray-400 mb-4">
            Asbest ist in Gebäuden bis 1993 weit verbreitet. Als zertifizierter Fachbetrieb 
            (Stufe D) sanieren wir asbesthaltige Materialien sicher und rechtskonform.
          </p>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Asbestzement-Wellplatten (Dächer/Fassaden)</span>
            </li>
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Bodenbeläge und Klebstoffe</span>
            </li>
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Feuerschutzbeschichtungen und Putze</span>
            </li>
          </ul>
        </article>
        
        <!-- Mineralwolle Card -->
        <article class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 hover:border-shiny-gold/50 transition-colors">
          <div class="w-16 h-16 bg-yellow-500/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Mineralwolle-Entsorgung (TRGS 521)</h3>
          <p class="text-gray-400 mb-4">
            Alte Mineralwolle (besonders aus den 60er-80er Jahren) kann gesundheitsschädliche 
            Fasern enthalten. Wir entsorgen sie fachgerecht nach den aktuellen Vorschriften.
          </p>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Dachdämmungen und Einblaswolle</span>
            </li>
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Wand- und Deckendämmungen</span>
            </li>
            <li class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Schutzmaßnahmen nach TRGS 521</span>
            </li>
          </ul>
        </article>
      </div>
      
      <div class="mt-12 text-center">
        <p class="text-gray-400 mb-6">
          Unsicher, ob in Ihrem Gebäude Asbest oder alte Mineralwolle verbaut ist?
        </p>
        <a href="/kontakt/" class="inline-flex items-center px-6 py-3 bg-shiny-gold text-white font-semibold rounded-lg shadow-lg hover:shadow-xl hover:bg-yellow-600 transition-all">
          Kostenlose Beratung vereinbaren
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-shiny-gold" aria-label="Call to Action">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Bereit für Ihr nächstes Projekt?
      </h2>
      <p class="text-white/90 text-lg mb-8">
