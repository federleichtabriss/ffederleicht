---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { label: 'Abrissarbeiten', href: '/leistungen/' },
    { label: 'Entkernung', href: '/leistungen/' },
    { label: 'Entrümpelung', href: '/leistungen/' },
    { label: 'Asbestsanierung', href: '/leistungen/' },
  ],
  company: [
    { label: 'Über Uns', href: '/ueber-uns/' },
    { label: 'Kontakt', href: '/kontakt/' },
    { label: 'Karriere', href: '/kontakt/' },
  ],
  legal: [
    { label: 'Impressum', href: '/impressum/' },
    { label: 'Datenschutz', href: '/datenschutz/' },
  ],
};

const contactInfo = {
  name: 'Federleicht Abriss Entkernung und Entrümpelung',
  owner: 'Ismail Dag',
  address: 'Johann-Wichernstrasse 9a',
  city: '31319 Sehnde',
  phone: '0155 67235344',
  phoneLink: '+4915567235344',
  email: 'Ismaildag@ymail.com',
};
---

<footer class="bg-gray-900 text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      
      <!-- Brand & Contact -->
      <div class="lg:col-span-1">
        <a href="/" class="mb-6 inline-block" aria-label="Federleicht Abriss - Zur Startseite">
          <img src="/images/logo_test.png" alt="Federleicht Logo" class="h-10 w-auto rounded-xl object-contain border border-shiny-gold/30 bg-gray-800" style="min-width: 120px;" />
        </a>
        
        <address class="not-italic space-y-2 text-concrete-light text-sm">
          <p class="font-medium text-white">{contactInfo.name}</p>
          <p>Inhaber: {contactInfo.owner}</p>
          <p>{contactInfo.address}</p>
          <p>{contactInfo.city}</p>
        </address>
        
        <div class="mt-6 space-y-3">
          <a 
            href={`tel:${contactInfo.phoneLink}`}
            class="flex items-center gap-3 text-concrete-light hover:text-shiny-gold transition-colors"
            aria-label={`Telefon: ${contactInfo.phone}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span class="text-sm">{contactInfo.phone}</span>
          </a>
          <a 
            href={`mailto:${contactInfo.email}`}
            class="flex items-center gap-3 text-concrete-light hover:text-shiny-gold transition-colors"
            aria-label={`E-Mail: ${contactInfo.email}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span class="text-sm">{contactInfo.email}</span>
          </a>
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">Leistungen</h3>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-concrete-light hover:text-shiny-gold transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">Unternehmen</h3>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-concrete-light hover:text-shiny-gold transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Trust Badges -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">Zertifiziert</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-3 bg-white/5 rounded-lg">
            <div class="w-10 h-10 bg-shiny-gold/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">TRGS 519</p>
              <p class="text-xs text-concrete-light">Asbestsanierung</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 bg-white/5 rounded-lg">
            <div class="w-10 h-10 bg-shiny-gold/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-shiny-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">TRGS 521</p>
              <p class="text-xs text-concrete-light">Mineralwolle</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-concrete-light text-center md:text-left">
          © {currentYear} {contactInfo.name}. Alle Rechte vorbehalten.
        </p>
        <nav class="flex items-center gap-6" aria-label="Rechtliche Links">
          {footerLinks.legal.map((link) => (
            <a 
              href={link.href}
              class="text-sm text-concrete-light hover:text-shiny-gold transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</footer>
